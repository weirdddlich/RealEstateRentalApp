<Window x:Class="RealEstateRental.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:oxy="clr-namespace:OxyPlot.Wpf;assembly=OxyPlot.Wpf"
        xmlns:converters="clr-namespace:RealEstateRental.Converters"
        mc:Ignorable="d"
        Title="Управление арендой коммерческой недвижимости"
        Height="780"
        Width="1150"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="LandlordVisibility" Invert="False" CollapseWhenFalse="True"/>
        <converters:BoolToVisibilityConverter x:Key="TenantVisibility" Invert="True" CollapseWhenFalse="True"/>
    </Window.Resources>
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Выйти из учётной записи" Click="Logout_Click"/>
                <Separator/>
                <MenuItem Header="Выход из программы" Click="ExitApp_Click"/>
            </MenuItem>
        </Menu>
        <ToolBar DockPanel.Dock="Top" ToolBarTray.IsLocked="True">
            <Button Content="Выйти из учётной записи" Click="Logout_Click" Padding="10,4"/>
        </ToolBar>
        <Grid Margin="10">
        <TabControl>
            <!-- Properties Tab -->
            <TabItem Header="Объекты недвижимости" Visibility="{Binding IsLandlord, Converter={StaticResource LandlordVisibility}}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Vertical">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Поиск (название / аренда)" VerticalAlignment="Center"/>
                            <TextBox Width="280" Margin="10,0,0,0" Text="{Binding PropertySearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Left" VerticalAlignment="Top">
                            <StackPanel Margin="0,0,20,0">
                                <TextBlock Text="Название"/>
                                <TextBox Width="220" Text="{Binding PropertyNameInput, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,20,0">
                                <TextBlock Text="Аренда в месяц"/>
                                <TextBox Width="120" Text="{Binding PropertyPriceInput, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                <Button Content="Добавить" Width="90" Margin="0,0,10,0" Click="AddProperty_Click"/>
                                <Button Content="Изменить" Width="90" Margin="0,0,10,0" Click="EditProperty_Click"/>
                                <Button Content="Удалить" Width="90" Click="DeleteProperty_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding PropertiesView}"
                              SelectedItem="{Binding SelectedProperty, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Аренда в месяц" Binding="{Binding PricePerMonth}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Tenants Tab -->
            <TabItem Header="Арендаторы" Visibility="{Binding IsLandlord, Converter={StaticResource LandlordVisibility}}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Vertical">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Поиск (имя)" VerticalAlignment="Center"/>
                            <TextBox Width="280" Margin="10,0,0,0" Text="{Binding TenantSearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Left" VerticalAlignment="Top">
                            <StackPanel Margin="0,0,20,0">
                                <TextBlock Text="Имя"/>
                                <TextBox Width="260" Text="{Binding TenantNameInput, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                <Button Content="Добавить" Width="90" Margin="0,0,10,0" Click="AddTenant_Click"/>
                                <Button Content="Изменить" Width="90" Margin="0,0,10,0" Click="EditTenant_Click"/>
                                <Button Content="Удалить" Width="90" Click="DeleteTenant_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding TenantsView}"
                              SelectedItem="{Binding SelectedTenant, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Contracts Tab -->
            <TabItem Header="Договоры">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="280" MinHeight="120"/>
                    </Grid.RowDefinitions>

                    <!-- Add/Edit Contract -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Left" VerticalAlignment="Top"
                                Visibility="{Binding IsLandlord, Converter={StaticResource LandlordVisibility}}">
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Арендатор"/>
                            <ComboBox Width="230"
                                      ItemsSource="{Binding Tenants}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding SelectedTenantForContract, Mode=TwoWay}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Объект"/>
                            <ComboBox Width="230"
                                      ItemsSource="{Binding Properties}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding SelectedPropertyForContract, Mode=TwoWay}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Дата начала"/>
                            <DatePicker Width="160" SelectedDate="{Binding ContractStartDateInput, Mode=TwoWay}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Дата окончания (необязательно)"/>
                            <DatePicker Width="160" SelectedDate="{Binding ContractEndDateInput, Mode=TwoWay}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Аренда в месяц (из объекта)"/>
                            <TextBox Width="140"
                                     Text="{Binding ContractMonthlyRentDisplay, Mode=OneWay}"
                                     IsReadOnly="True"
                                     Background="#FFF0F0F0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                            <Button Content="Добавить" Width="95" Margin="0,0,10,0" Click="AddContract_Click"/>
                            <Button Content="Изменить" Width="95" Margin="0,0,10,0" Click="EditContract_Click"/>
                            <Button Content="Удалить" Width="95" Click="DeleteContract_Click"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="20,0,0,0">
                            <Button Content="Прикрепить файл" Width="140" Margin="0,0,8,0" Click="AttachContractFile_Click"/>
                            <Button Content="Открыть файл" Width="120" Margin="0,0,8,0" Click="OpenContractFile_Click"/>
                            <Button Content="Скачать файл" Width="120" Margin="0,0,8,0" Click="SaveContractFileAs_Click"/>
                            <Button Content="Убрать файл" Width="110" Click="RemoveContractFile_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Filtering / Export / Bulk Delete -->
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search + Filters -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Vertical" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Поиск (арендатор / объект / аренда):" VerticalAlignment="Center"/>
                            <TextBox Width="320" Margin="10,0,0,0" Text="{Binding ContractSearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Фильтр по долгу:" VerticalAlignment="Center" Margin="0,0,10,0"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                <TextBlock Text="Мин" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox Width="110" Text="{Binding ContractDebtMinText, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                <TextBlock Text="Макс" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox Width="110" Text="{Binding ContractDebtMaxText, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Статус" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox Width="170"
                                          SelectedValuePath="Tag"
                                          SelectedValue="{Binding ContractDebtStatusFilterValue, Mode=TwoWay}">
                                    <ComboBoxItem Content="Все" Tag="All" IsSelected="True"/>
                                    <ComboBoxItem Content="Полностью оплачено" Tag="FullyPaid"/>
                                    <ComboBoxItem Content="Частично оплачено" Tag="PartiallyPaid"/>
                                    <ComboBoxItem Content="Просрочено" Tag="Overdue"/>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                        </StackPanel>

                        <!-- Unpaid notification -->
                        <Border Grid.Row="1" Grid.Column="0"
                                Background="#44FF0000"
                                Padding="10"
                                CornerRadius="4"
                                Visibility="{Binding UnpaidNotificationVisibility}">
                            <TextBlock Text="{Binding UnpaidNotificationText}" FontWeight="Bold"/>
                        </Border>

                        <!-- Export buttons -->
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Экспорт договоров в Excel" Width="250" Margin="0,0,8,0" Click="ExportContractsToExcel_Click"/>
                            <Button Content="Экспорт договоров в PDF" Width="220" Click="ExportContractsToPdf_Click"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left"
                                    Visibility="{Binding IsLandlord, Converter={StaticResource LandlordVisibility}}">
                            <Button Content="Удалить выбранные договоры" Width="260" Margin="0,0,10,0" Click="DeleteSelectedContracts_Click"/>
                            <Button Content="Сбросить выбор договоров" Width="240" Click="ClearSelectedContracts_Click"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Обновить данные" Width="160" Click="ReloadData_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- Contracts DataGrid -->
                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding ContractsView}"
                              SelectedItem="{Binding SelectedContract, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="False"
                              CanUserAddRows="False"
                              CanUserSortColumns="True">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DebtStatus}" Value="FullyPaid">
                                        <Setter Property="Background" Value="#CC77DD77"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DebtStatus}" Value="PartiallyPaid">
                                        <Setter Property="Background" Value="#CCFFD966"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DebtStatus}" Value="Overdue">
                                        <Setter Property="Background" Value="#CCFF6B6B"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Удалить"
                                                      Binding="{Binding IsSelectedForBulkDelete}"
                                                      IsReadOnly="False"
                                                      Width="55"
                                                      Visibility="{Binding DataContext.IsLandlord, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource LandlordVisibility}}"/>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="55" CanUserSort="False" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Арендатор" Binding="{Binding Tenant.Name}" Width="180" CanUserSort="False" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Объект" Binding="{Binding Property.Name}" Width="210" CanUserSort="False" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Дата начала"
                                                  Binding="{Binding StartDate, StringFormat=\{0:yyyy-MM-dd\}}"
                                                  Width="120"
                                                  SortMemberPath="StartDate"
                                                  CanUserSort="True"
                                                  IsReadOnly="True"/>
                            <DataGridTextColumn Header="Дата окончания"
                                                  Binding="{Binding EndDate, StringFormat=\{0:yyyy-MM-dd\}}"
                                                  Width="120"
                                                  CanUserSort="False"
                                                  IsReadOnly="True"/>
                            <DataGridTextColumn Header="Аренда в месяц" Binding="{Binding MonthlyRent}" Width="160" CanUserSort="False" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Задолженность"
                                                  Binding="{Binding Debt}"
                                                  Width="120"
                                                  SortMemberPath="Debt"
                                                  CanUserSort="True"
                                                  IsReadOnly="True"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding DebtStatusText}" Width="140" CanUserSort="False" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Файл договора" Binding="{Binding ContractFileName}" Width="180" CanUserSort="False" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <GridSplitter Grid.Row="3"
                                  Height="6"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  Background="#FFBFBFBF"
                                  ResizeDirection="Rows"
                                  ResizeBehavior="PreviousAndNext"/>

                    <!-- Schedule + Analytics -->
                    <StackPanel Grid.Row="4" Orientation="Vertical">
                        <Expander Header="Платежный график (выбранный договор)" IsExpanded="True" Margin="0,0,0,10">
                            <DataGrid ItemsSource="{Binding ContractScheduleItems}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPaid}" Value="True">
                                                <Setter Property="Background" Value="#CC77DD77"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                <Setter Property="Background" Value="#CCFF6B6B"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding HasPartialPayment}" Value="True">
                                                <Setter Property="Background" Value="#CCFFD966"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Ожидаемая дата" Binding="{Binding ExpectedDate, StringFormat=\{0:yyyy-MM-dd\}}" Width="170"/>
                                    <DataGridTextColumn Header="Ожидаемая сумма" Binding="{Binding ExpectedAmount}" Width="140"/>
                                    <DataGridTextColumn Header="Оплачено" Binding="{Binding PaidAmount}" Width="120"/>
                                    <DataGridTextColumn Header="Статус" Binding="{Binding StatusText}" Width="130"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Expander>

                        <Expander Header="Аналитика" IsExpanded="True">
                            <Grid Margin="0,0,0,10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="200"/>
                                    <RowDefinition Height="200"/>
                                    <RowDefinition Height="200"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <GroupBox Header="Договоров по объектам" Grid.Row="0" Margin="0,0,0,6">
                                    <oxy:PlotView x:Name="ContractsPerPropertyPlotView" />
                                </GroupBox>
                                <GroupBox Header="Общая задолженность по арендаторам" Grid.Row="1" Margin="0,0,0,6">
                                    <oxy:PlotView x:Name="DebtPerTenantPlotView" />
                                </GroupBox>
                                <GroupBox Header="История платежей по времени" Grid.Row="2">
                                    <oxy:PlotView x:Name="PaymentHistoryPlotView" />
                                </GroupBox>
                            </Grid>
                        </Expander>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Payments Tab -->
            <TabItem Header="Платежи">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Add/Edit Payment (только арендатор) -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Left" VerticalAlignment="Top"
                                Visibility="{Binding IsLandlord, Converter={StaticResource TenantVisibility}}">
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Договор"/>
                            <ComboBox Width="340"
                                      ItemsSource="{Binding Contracts}"
                                      SelectedItem="{Binding SelectedContractForPayment, Mode=TwoWay}"
                                      DisplayMemberPath="DisplayName"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Дата платежа"/>
                            <DatePicker Width="160" SelectedDate="{Binding PaymentDateInput, Mode=TwoWay}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Сумма"/>
                            <TextBox Width="150" Text="{Binding PaymentAmountInput, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                            <Button Content="Добавить" Width="95" Margin="0,0,10,0" Click="AddPayment_Click"/>
                            <Button Content="Изменить" Width="95" Margin="0,0,10,0" Click="EditPayment_Click"/>
                            <Button Content="Удалить" Width="95" Click="DeletePayment_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Search -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Поиск (арендатор / объект / сумма / № договора):" VerticalAlignment="Center"/>
                        <TextBox Width="360" Margin="10,0,0,0" Text="{Binding PaymentSearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Export / Bulk Delete -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
                        <Button Content="Экспорт платежей в Excel" Width="240" Margin="0,0,8,0" Click="ExportPaymentsToExcel_Click"/>
                        <Button Content="Экспорт платежей в PDF" Width="220" Margin="0,0,30,0" Click="ExportPaymentsToPdf_Click"/>
                        <StackPanel Orientation="Horizontal" Visibility="{Binding IsLandlord, Converter={StaticResource TenantVisibility}}">
                            <Button Content="Удалить выбранные платежи" Width="280" Margin="0,0,10,0" Click="DeleteSelectedPayments_Click"/>
                            <Button Content="Сбросить выбор платежей" Width="230" Click="ClearSelectedPayments_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Payments DataGrid -->
                    <DataGrid x:Name="PaymentsDataGrid"
                              Grid.Row="3"
                              ItemsSource="{Binding PaymentsView}"
                              SelectedItem="{Binding SelectedPayment, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="False"
                              CanUserAddRows="False"
                              CanUserSortColumns="True">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                        <Setter Property="Background" Value="#CCFF6B6B"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Удалить"
                                                      Binding="{Binding IsSelectedForBulkDelete}"
                                                      IsReadOnly="False"
                                                      Width="55"
                                                      Visibility="{Binding DataContext.IsLandlord, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource TenantVisibility}}"/>
                            <DataGridTextColumn Header="№" Binding="{Binding Id}" Width="55" SortMemberPath="Id" IsReadOnly="True"/>
                            <DataGridTextColumn Header="№ договора" Binding="{Binding Contract.Id}" Width="110" SortMemberPath="Contract.Id" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Арендатор" Binding="{Binding Contract.Tenant.Name}" Width="150" SortMemberPath="Contract.Tenant.Name" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Объект" Binding="{Binding Contract.Property.Name}" Width="190" SortMemberPath="Contract.Property.Name" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Дата платежа"
                                                  Binding="{Binding PaymentDate, StringFormat=\{0:yyyy-MM-dd\}}"
                                                  Width="140"
                                                  SortMemberPath="PaymentDate"
                                                  IsReadOnly="True"/>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding Amount}" Width="120" SortMemberPath="Amount" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Просрочено" Binding="{Binding IsOverdueText}" Width="95" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
    </DockPanel>
</Window>